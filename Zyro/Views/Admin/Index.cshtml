        window.onload = function () {
            var modal = new bootstrap.Modal(document.getElementById('messageModal'));
            modal.show();
        };
    </script>

    <div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body text-center">
                    <h5>@TempData["ErrorMessageAddEmployeee"]</h5>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger w-100 rounded-pill" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@if (TempData["SuccessMessageContactDelete"] != null)
{
    <script>
        window.onload = function () {
            var modal = new bootstrap.Modal(document.getElementById('messageModal'));
            modal.show();
        };
    </script>

    <div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body text-center">
                    <h5>@TempData["SuccessMessageContactDelete"]</h5>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger w-100 rounded-pill" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* Contact *@


<div class="container-fluid pt-1 px-1">
    <div class="row g-4">
        <div class="col-sm-12 col-md-6 col-xl-4">
            <div class="h-100 bg-light rounded p-4">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0">Messages</h6>
                    <a href="#" data-bs-toggle="modal" data-bs-target="#contactModal" style="color:#2373AE;  font-weight:500;">Show All</a>
                </div>

                @if (Model.Con != null && Model.Con.Any())
                {
                    foreach (var item in Model.Con.Take(5))
                    {
                        <div class="d-flex align-items-center border-bottom py-2">
                            <div class="w-100">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@item.Name</h6>
                                </div>
                                <span>
                                    @if (!string.IsNullOrWhiteSpace(item.Subject))
                                    {
                                        @(item.Subject.Length > 50 ? item.Subject.Substring(0, 50) + "..." : item.Subject)
                                    }
                                    else
                                    {
                                        <text>No subject</text>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning text-center mb-0">No messages yet.</div>
                }

                <!-- Hint text below -->
                <div class="text-center mt-2" style="font-size:0.85rem; color:#555;">
                    Click <strong>'Show All'</strong> for more messages.
                </div>
            </div>
        </div>


        <!-- Bootstrap Modal -->
        <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="contactModalLabel">All Contact Messages</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (Model.Con != null && Model.Con.Any())
                        {
                            <table class="table table-striped table-bordered text-center rounded-lg">
                                <thead class="rounded-top">
                                    <tr>
                                        <th>#</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Phone Number</th>
                                        <th>Project</th>
                                        <th>Subject</th>
                                        <th>Message</th>
                                        <th>Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Con)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.Name</td>
                                            <td>@item.Email</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Project</td>
                                            <td>@item.Subject</td>
                                            <td>@item.Message</td>
                                            <td>@item.Date</td>
                                            <td>
                                                <a href="@Url.Action("ViewContactChat", "Admin", new { contactId = item.Id })"
                                                   class="btn btn-sm openchat-btn open-chat"
                                                   data-contact-id="@item.Id">
                                                    Open Chat
                                                </a>


                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">No contact messages found.</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger rounded-pill" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
        @* Calender *@
        <div class="col-sm-12 col-md-6 col-xl-4">
            <div class="h-100 bg-light rounded p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h6 class="mb-0 text-center">Calender</h6>
                </div>
                <!-- Calendar container -->
                <div id="calender"></div>
            </div>
        </div>

        @* TASk *@

        <div class="col-sm-12 col-md-6 col-xl-4">
            <div class="h-100 bg-light rounded p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h6 class="mb-0">Tasks</h6>
                    <!-- Show All -->
                    <a href="#" data-bs-toggle="modal" data-bs-target="#taskModal" style="color:#235693;  font-weight:500;">
                        Show All
                    </a>
                </div>

                <!-- Alerts -->
                @if (TempData["SuccessMessageTask"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessageTask"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessageTask"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessageTask"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <!-- Add new task -->
                <form asp-action="CreateTask" method="post" class="mb-3 d-flex gap-2" onsubmit="return validateTaskInput()">
                    <input asp-for="NewTask" id="newTaskInput" class="form-control" placeholder="Enter new task" />
                    <input asp-for="Name" type="hidden" value="@userName" />
                    <input asp-for="Email" type="hidden" value="@userEmail" />
                    <button type="submit" class="btn btn-success">Add</button>
                </form>

                <!-- Short Preview -->
                <ul class="list-group list-group-flush">
                    @if (Model.Task != null && Model.Task.Any())
                    {
                        @foreach (var item in Model.Task.Take(5))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @(item.Task.Length > 25 ? item.Task.Substring(0, 25) + "..." : item.Task)
                                </span>
                                <form asp-action="TaskDelete" method="post" class="mb-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fa fa-times"></i>
                                    </button>
                                </form>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center text-muted">No tasks found</li>
                    }
                </ul>
            </div>
        </div>

        <!-- ================= MODAL FOR FULL TASK LIST ================= -->
        <div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="taskModalLabel">All Tasks</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">

                        <!-- ===== modal ke andar bhi ALERTS ===== -->
                        @if (TempData["SuccessMessageTask"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @TempData["SuccessMessageTask"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }
                        @if (TempData["ErrorMessageTask"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @TempData["ErrorMessageTask"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        @if (Model.Task != null && Model.Task.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-bordered text-center align-middle">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Task</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Task)
                                        {
                                            <tr>
                                                <td>@item.Id</td>
                                                <td>@item.Task</td>
                                                <td>
                                                    <form asp-action="TaskDelete" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">No tasks found.</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== Simple JS Validation ===== -->
        <script>
            function validateTaskInput() {
                var input = document.getElementById("newTaskInput").value.trim();
                if (input === "") {
                    alert("Please enter a task before submitting.");
                    return false; // form submit ruk jaayega
                }
                return true;
            }
        </script>


        @* Testimonials *@

        <div class="modal fade" id="testimonialModal" tabindex="-1" aria-labelledby="testimonialModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="testimonialModalLabel">All Testimonials</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (Model.Tes != null && Model.Tes.Any())
                        {
                            <table class="table table-striped table-bordered text-center rounded-lg">
                                <thead class="rounded-top">
                                    <tr>
                                        <th>#</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Remarks</th>
                                        <th>Action</th>
                                        <th>Manage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Tes)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.Name</td>
                                            <td>@item.Email</td>
                                            <td>@item.Remarks</td>
                                            @* <td>@item.Action</td> *@
                                            <td>
                                                @* <form asp-action="UpdateTestAction" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-success mt-1 w-100" onclick="return confirm('Are you sure you want to publish this review?')">Publish</button>
                                                </form>
                                                <form asp-action="UpdateTestActionTwo" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-success mt-1 w-100" onclick="return confirm('Are you sure you want to hide this review?')">Hide</button>
                                                </form> *@
                                                <form asp-action="DeleteTestimonial" method="post" onsubmit="return confirm('Are you sure you want to delete this service?');">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-danger btn-sm mt-1 w-100">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">No testimonials found.</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger rounded-pill" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-12 col-xl-6">
            <div class="bg-light rounded h-100 p-3">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h6 class="mb-0">Testimonials</h6>
                    <a href="#" data-bs-toggle="modal" data-bs-target="#testimonialModal" style="color: #2373AE; font-weight:500;">Show All</a>
                </div>

                @if (!Model.Tes.Any())
                {
                    <div class="alert alert-warning text-center">No testimonials found.</div>
                }
                else
                {
                    <div class="owl-carousel testimonial-carousel">
                        @foreach (var item in Model.Tes)
                        {
                            <div class="testimonial-item text-center">
                                <h5 class="mb-1">@item.Name</h5>
                                <p class="mb-0">@item.Remarks</p>
                            </div>
                        }
                    </div>
                }

                <!-- Hint text below carousel -->
                <div class="text-center mt-2" style="font-size:0.85rem; color:#555;">
                    Click <strong>'Show All'</strong> for more testimonials.
                </div>
            </div>
        </div>



        <div class="col-sm-12 col-xl-6">
            <div class="bg-light rounded h-100 p-4">
                <iframe class="position-relative rounded w-100 h-100"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3001156.4288297426!2d-78.01371936852176!3d42.72876761954724!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4ccc4bf0f123a5a9%3A0xddcfc6c1de189567!2sNew%20York%2C%20USA!5e0!3m2!1sen!2sbd!4v1603794290143!5m2!1sen!2sbd"
                        frameborder="0" style="border:0;" allowfullscreen="" aria-hidden="false"
                        tabindex="0"></iframe>
            </div>
        </div>
    </div>
</div>
<!-- Chart End -->

<div class="modal fade" id="chatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <!-- Partial view will load here -->
        </div>
    </div>
</div>



<script>
    $(document).on("click", ".open-chat", function (e) {
        e.preventDefault();
        const url = $(this).attr("href");

        $("#chatModal .modal-content").load(url, function () {
            $("#chatModal").modal("show");
        });
    });
</script>

