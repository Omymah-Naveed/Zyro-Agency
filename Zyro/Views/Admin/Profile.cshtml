@model Zyro.Models.AdminRegisteration

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Profile";
    var userName = Context.Session.GetString("usernameadmin") ?? "";
    var userEmail = Context.Session.GetString("useremailadmin") ?? "";
}
<style>
    /* Theme Colors */
    :root {
        --primary-color: #2373AD; /* Light Blue */
        --primary-dark: #235695; /* Dark Blue */
    }

    /* Override Bootstrap primary */
    .bg-primary {
        background-color: var(--primary-color) !important;
    }

    .text-primary {
        color: var(--primary-color) !important;
    }

    .border-primary {
        border-color: var(--primary-color) !important;
    }

    .btn-primary {
        background-color: var(--primary-dark) !important;
        border-color: var(--primary-dark) !important;
    }

        .btn-primary:hover {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
        }

    .badge.bg-primary {
        background-color: var(--primary-dark) !important;
    }

    /* Profile Page Theme Colors */

    /* Tabs Active State */
    .nav-pills .nav-link.active {
        background-color: #2373AD !important;
        color: #fff !important;
        font-weight: 600;
    }

    .nav-pills .nav-link {
        color: #235695 !important;
    }

        .nav-pills .nav-link:hover {
            background-color: #e9f2fb !important;
            color: #2373AD !important;
        }

    /* Card Headings */
    .card-body h5 {
        color: #235695 !important;
        font-weight: 700;
    }

    /* Labels */
    .form-label {
        color: #235695 !important;
        font-weight: 500;
    }

    /* Inputs Focus */
    .form-control:focus {
        border-color: #2373AD !important;
        box-shadow: 0 0 0 0.2rem rgba(35, 115, 173, 0.25);
    }

    /* Buttons */
    .btn-primary {
        background-color: #235695 !important;
        border-color: #235695 !important;
    }

        .btn-primary:hover {
            background-color: #2373AD !important;
            border-color: #2373AD !important;
        }

    .btn-success {
        background-color: #235695 !important;
        border-color: #235695 !important;
    }

        .btn-success:hover {
            background-color: #2373AD !important;
            border-color: #2373AD !important;
        }

    /* Error Messages */
    .text-danger {
        color: #d9534f !important;
    }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #235695;
    }

        .password-toggle:hover {
            color: #2373AD;
        }


    /* Custom Badge CSS with #235695 gradient */
    .custom-badge {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, #235695, #3a6fb0); /* Gradient from #235695 to lighter blue */
        border-radius: 50px; /* Rounded pill shape */
        box-shadow: 0 4px 6px rgba(0,0,0,0.15); /* Subtle shadow */
        transition: transform 0.2s, box-shadow 0.2s; /* Smooth hover effect */
        cursor: default;
    }

        .custom-badge:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 10px rgba(0,0,0,0.2); /* Slightly bigger shadow on hover */
        }

    /* Add Save Changes Button */
    .btn-save-changes {
        background-color: #235693;
        color: #fff;
        border: 2px solid #235693;
        font-weight: 500;
        padding: 0.45rem 1rem;
        transition: all 0.3s ease;
    }

    .btn-save-changes:hover {
            background-color: #fff;
            color: #235693;
            border-color: #235693;
        }

        /* Focus state */
        .btn-save-changes:focus,
    .btn-save-changes:active {
            outline: none; /* remove default bootstrap blue outline */
            box-shadow: 0 0 0 0.2rem rgba(35, 86, 147, 0.4); /* custom shadow with theme color */
            border-color: #235693;
        }

    /* Btn Update Password */
    .btn-update-pass {
        background-color: #235693;
        color: #fff;
        border: 2px solid #235693;
        font-weight: 500;
        padding: 0.45rem 1rem;
        transition: all 0.3s ease;
    }

        .btn-update-pass:hover {
            background-color: #fff;
            color: #235693;
            border-color: #235693;
        }

        /* Focus state */
        .btn-update-pass:focus,
        .btn-update-pass:active {
            outline: none; /* remove default bootstrap blue outline */
            box-shadow: 0 0 0 0.2rem rgba(35, 86, 147, 0.4); /* custom shadow with theme color */
            border-color: #235693;
        }
</style>

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="row g-4 w-100 justify-content-center">

        <!-- Sidebar Card -->
        <div class="col-lg-6 col-md-8 col-sm-12 mx-auto">
            <div class="card border-0 shadow-lg rounded-3 w-100">
                <div class="card-body text-center p-4">
                    <div class="position-relative d-inline-block">
                        <img id="profileImage" src="~/profile_images/@Model?.ImagePath"
                             class="rounded-circle border border-3 border-primary shadow-sm"
                             width="140" height="140"
                             alt="Profile Photo" />

                        <!-- Camera Icon -->
                        <span class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow"
                              style="width:36px; height:36px; cursor:pointer;"
                              data-bs-toggle="modal" data-bs-target="#profileModal">
                            <i class="fas fa-eye"></i>
                        </span>
                    </div>
                    <h4 class="mt-3 mb-1 fw-bold">@Model?.Name</h4>
                    <p class="text-muted mb-2">@Model?.Email</p>
                    <span class="badge custom-badge">
                        @(Model?.Role == 2 ? "Administrator" : (Model?.Role == 1 ? "Employee" : "Unknown"))
                    </span>
                </div>
            </div>
        </div>

        <!-- Modal -->
        <div class="modal fade" id="profileModal" tabindex="-1" aria-labelledby="profileModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0">
                    <div class="modal-body text-center">
                        <img src="~/profile_images/@Model?.ImagePath" class="img-fluid rounded" alt="Profile Photo">
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Profile Content Card -->
        <div class="col-lg-8 col-md-10 col-sm-12 mx-auto">
            <div class="card border-0 shadow-lg rounded-3 w-100">
                <div class="card-header bg-white border-bottom-0">
                    <ul class="nav nav-pills nav-fill rounded bg-light p-1">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#overview">
                                <i class="fas fa-id-card me-1"></i>Overview
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#edit">
                                <i class="fas fa-edit me-1"></i>Edit Profile
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#password">
                                <i class="fas fa-lock me-1"></i>Password
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="card-body tab-content p-4">

                    <!-- Overview -->
                    <div class="tab-pane fade show active" id="overview">
                        <h5 class="fw-bold mb-3">Profile Details</h5>
                        <div class="row g-3">
                            <div class="col-sm-6"><i class="fas fa-user me-1 text-primary"></i><strong>Name:</strong><br>@Model?.Name</div>
                            <div class="col-sm-6"><i class="fas fa-envelope me-1 text-primary"></i><strong>Email:</strong><br>@Model?.Email</div>
                            <div class="col-sm-6">
                                <i class="fas fa-hourglass-half me-1 text-primary"></i><strong>Age:</strong><br>@Model?.Age
                            </div>
                            <div class="col-sm-6">
                                <i class="fas fa-map-marker-alt me-1 text-primary"></i><strong>City:</strong><br>@Model?.City
                            </div>
                            <div class="col-sm-6"><i class="fas fa-phone me-1 text-primary"></i><strong>Phone:</strong><br>@Model?.Phone</div>
                            <div class="col-sm-6"><i class="fas fa-user-shield me-1 text-primary"></i><strong>Role:</strong><br>@(Model?.Role == 2 ? "Administrator" : (Model?.Role == 1 ? "Employee" : "Unknown"))</div>
                        </div>
                    </div>

                    <!-- Edit Profile -->
                    <div class="tab-pane fade" id="edit">
                        <h5 class="fw-bold mb-3">Edit Profile</h5>
                        <form method="post" asp-action="UpdateProfile" enctype="multipart/form-data" class="row g-3">
                            <input type="hidden" name="Id" value="@Model?.Id" />

                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-user me-1 text-primary"></i>Full Name</label>
                                <input type="text" name="Name" value="@userName" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-envelope me-1 text-primary"></i>Email</label>
                                <input type="email" name="Email" value="@userEmail" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-hourglass-half me-1 text-primary"></i>Age</label>
                                <input type="text" name="Age" value="@Model?.Age" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-map-marker-alt me-1 text-primary"></i>City</label>
                                <input type="text" name="City" value="@Model?.City" class="form-control" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label"><i class="fas fa-phone me-1 text-primary"></i>Phone</label>
                                <input type="text" name="Phone" value="@Model?.Phone" class="form-control" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label"><i class="fas fa-image me-1 text-primary"></i>Change Profile Picture</label>
                                <input type="file" name="ProfileImage" class="form-control" accept=".jpg,.jpeg,.png" />
                            </div>

                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-save-changes px-4"><i class="fas fa-save me-1"></i>Save Changes</button>
                            </div>
                        </form>
                    </div>

                    <!-- Change Password -->
                    <div class="tab-pane fade" id="password">
                        <h5 class="fw-bold mb-3">Change Password</h5>
                        <form method="post" asp-action="ChangePassword" id="changePasswordForm" novalidate class="row g-3">
                            <input type="hidden" name="Id" value="@Model?.Id" />

                            <div class="col-12">
                                <label class="form-label"><i class="fas fa-lock me-1 text-primary"></i>Current Password</label>
                                <div class="input-group">
                                    <input type="password" name="CurrentPassword" id="currentPassword" class="form-control" required />
                                    <span class="input-group-text" onclick="togglePassword('currentPassword','eyeIconCurrent')" style="cursor:pointer;">
                                        <i class="fas fa-eye" id="eyeIconCurrent"></i>
                                    </span>
                                </div>
                                <small id="currentPasswordError" class="text-danger d-none">Please enter your current password.</small>
                            </div>

                            <div class="col-12">
                                <label class="form-label"><i class="fas fa-lock me-1 text-primary"></i>New Password</label>
                                <div class="input-group">
                                    <input type="password" name="NewPassword" id="newPassword" class="form-control" required minlength="6" maxlength="20" />
                                    <span class="input-group-text" onclick="togglePassword('newPassword','eyeIconNew')" style="cursor:pointer;">
                                        <i class="fas fa-eye" id="eyeIconNew"></i>
                                    </span>
                                </div>
                                <small id="newPasswordError" class="text-danger d-none">Password must be 6–20 chars, include letters & numbers.</small>
                            </div>

                            <div class="col-12">
                                <label class="form-label"><i class="fas fa-lock me-1 text-primary"></i>Confirm Password</label>
                                <div class="input-group">
                                    <input type="password" name="ConfirmPassword" id="confirmPassword" class="form-control" required />
                                    <span class="input-group-text" onclick="togglePassword('confirmPassword','eyeIconConfirm')" style="cursor:pointer;">
                                        <i class="fas fa-eye" id="eyeIconConfirm"></i>
                                    </span>
                                </div>
                                <small id="confirmPasswordError" class="text-danger d-none">Passwords do not match.</small>
                            </div>

                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-update-pass px-4"><i class="fas fa-check me-1"></i>Update Password</button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

            <!-- Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3 shadow-sm">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessageProfile"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3 shadow-sm">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessageProfile"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, eyeIconId) {
            var passwordField = document.getElementById(inputId);
            var eyeIcon = document.getElementById(eyeIconId);
            if (passwordField.type === "password") {
                passwordField.type = "text";
                eyeIcon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                passwordField.type = "password";
                eyeIcon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
        document.addEventListener("DOMContentLoaded", function () {
            const currentPassword = document.getElementById("currentPassword");
            const newPassword = document.getElementById("newPassword");
            const confirmPassword = document.getElementById("confirmPassword");
            const currentPasswordError = document.getElementById("currentPasswordError");
            const newPasswordError = document.getElementById("newPasswordError");
            const confirmPasswordError = document.getElementById("confirmPasswordError");
            const passRegex = /^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{6,20}$/;
            newPassword.addEventListener("input", function () {
                newPasswordError.classList.toggle("d-none", passRegex.test(newPassword.value));
            });
            confirmPassword.addEventListener("input", function () {
                confirmPasswordError.classList.toggle("d-none", newPassword.value === confirmPassword.value);
            });
            document.getElementById("changePasswordForm").addEventListener("submit", function (e) {
                let valid = true;
                if (currentPassword.value.trim() === "") {
                    currentPasswordError.classList.remove("d-none"); valid = false;
                } else currentPasswordError.classList.add("d-none");
                if (!passRegex.test(newPassword.value)) { newPasswordError.classList.remove("d-none"); valid = false; }
                if (newPassword.value !== confirmPassword.value) { confirmPasswordError.classList.remove("d-none"); valid = false; }
                if (!valid) e.preventDefault();
            });
        });
    </script>
}
