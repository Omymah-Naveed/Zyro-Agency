@model AboutUViewModel

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "AboutUs";
}

<style>
    .btn-upload {
        background: #235695;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 5px;
        font-size: 16px;
        transition: 0.3s;
    }

        .btn-upload:hover {
            background: #2373AC;
            color: ghostwhite;
        }

    .form-floating > .form-control:focus,
    .form-floating > .form-select:focus {
        border-color: #44B1DA !important;
        box-shadow: none;
    }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-select:focus ~ label {
            color: #2373AC !important;
            font-weight: bold;
        }

    /* Eye button inside label fix */
    .form-floating label {
        display: flex;
        align-items: center; /* vertically center */
        justify-content: space-between; /* push button to right */
        width: 100%;
    }

    .form-floating .btn-eye {
        border: none;
        background: transparent;
        color: #235695;
        font-size: 1.1rem;
        cursor: pointer;
        padding: 0;
        margin-left: 8px;
    }

        .form-floating .btn-eye:hover {
            color: #133b6d;
        }
</style>

<!-- Upload Blog Form -->
<div class="container-xxl">
    <div class="container py-5 px-lg-5">
        <div class="wow fadeInUp" data-wow-delay="0.1s">
            <h1 class="text-center mb-5">Upload About Us</h1>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="wow fadeInUp" data-wow-delay="0.3s">
                    <form asp-action="AddAboutUs" enctype="multipart/form-data" method="post" class="shadow p-4 rounded bg-white">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Title" class="form-control" required placeholder="Enter Service Title (One)" />
                                    <label asp-for="Title">About Us Title One</label>
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Description" class="form-control" placeholder="Enter Description (One)" />
                                    <label asp-for="Description">About Us Description (One)</label>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="TitleTwo" class="form-control" required placeholder="Enter Service Title (Two)" />
                                    <label asp-for="TitleTwo">About Us Title (Two)</label>
                                    <span asp-validation-for="TitleTwo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="DescriptionTwo" class="form-control" placeholder="Enter Description (Two)" />
                                    <label asp-for="DescriptionTwo">About Us Description (Two)</label>
                                    <span asp-validation-for="DescriptionTwo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Image" type="file" class="form-control" />
                                    <label asp-for="Image">Upload Image</label>
                                    <span asp-validation-for="Image" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Password Field with Eye inside Label -->
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input type="password" class="form-control" placeholder="Enter Password" id="PasswordInput" />
                                    <label for="PasswordInput">
                                        Password
                                        <button type="button" class="btn-eye" onclick="togglePassword(this)">
                                            <i class="bi bi-eye-fill"></i>
                                        </button>
                                    </label>
                                </div>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn btn-upload w-100 rounded-pill">Upload Blog</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword(button) {
        const input = document.getElementById("PasswordInput");
        const icon = button.querySelector("i");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye-fill", "bi-eye-slash-fill");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-slash-fill", "bi-eye-fill");
        }
    }
</script>
