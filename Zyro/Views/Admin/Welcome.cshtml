@model Zyro.Models.AdminRegisterationWelcomeViewModel
@{
    ViewData["Title"] = "Welcome";
}
<head>
    <meta charset="utf-8">
    <title>DASHMIN Admin</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="~/img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa; /* Light gray background */
        }

        .content-container {
            width: 80%;
            max-width: 900px;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
        }

        .content-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
            padding-top: 20px;
        }
    </style>
</head>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9">

            <!-- Header -->
            <div class="mb-4 text-center">
                <h2 class="fw-bold mb-1">Welcome, @Model.Name 👋</h2>
                <p class="text-muted mb-0">Complete your profile to unlock the full experience.</p>
            </div>

            <!-- Steps -->
            <div class="row g-3">

                <!-- Step: Phone -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#phoneModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasPhone)
                                {
                                    <i class="bi bi-telephone-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-telephone-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 1: Add Phone</h6>
                                    @if (Model.HasPhone)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasPhone)
                                    {
                                        @Model.Phone
                                    }
                                    else
                                    {
                                        @:No phone provided
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: Profile Picture -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#pictureModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasProfilePicture)
                                {
                                    <i class="bi bi-person-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-person-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 2: Upload Profile Picture</h6>
                                    @if (Model.HasProfilePicture)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasProfilePicture)
                                    {
                                        @:Picture uploaded
                                    }
                                    else
                                    {
                                        @:No picture uploaded
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: City -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#cityModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasCity)
                                {
                                    <i class="bi bi-geo-alt-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-geo-alt text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 3: Select City</h6>
                                    @if (Model.HasCity)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasCity)
                                    {
                                        @Model.City
                                    }
                                    else
                                    {
                                        @:No city selected
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: Age -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#ageModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasAge)
                                {
                                    <i class="bi bi-calendar-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-calendar-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 4: Add Age</h6>
                                    @if (Model.HasAge)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasAge)
                                    {
                                        @Model.Age
                                    }
                                    else
                                    {
                                        @:No age provided
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA -->
            @if (Model.HasPhone && Model.HasProfilePicture && Model.HasCity && Model.HasAge)
            {
                <div class="d-grid mt-4">
                    <form asp-action="SaveProfile" asp-controller="Admin" method="post" enctype="multipart/form-data">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill">
                            Save Profile
                        </button>
                    </form>
                </div>
            }


        </div>
    </div>
</div>


<!-- MODALS -->

<!-- Phone Modal -->
<div class="modal fade" id="phoneModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdatePhone" asp-controller="Admin" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Update Phone</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" name="Phone" class="form-control" placeholder="Enter phone number" value="@Model.Phone" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save Phone</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Profile Picture Modal -->
<div class="modal fade" id="pictureModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SaveImageWelcome" asp-controller="Admin" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Upload Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="file" name="ProfilePicture" class="form-control" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- City Modal -->
<div class="modal fade" id="cityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateCity" asp-controller="Admin" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Enter City</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" name="City" class="form-control" placeholder="Enter your city" value="@Model.City" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save City</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Age Modal -->
<div class="modal fade" id="ageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateAge" asp-controller="Admin" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Add Age</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="number" name="Age" class="form-control" placeholder="Enter your age" value="@Model.Age" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save Age</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- JavaScript Libraries -->
<!-- JavaScript Libraries -->
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/chart/chart.min.js"></script>
<script src="~/lib/easing/easing.min.js"></script>
<script src="~/lib/waypoints/waypoints.min.js"></script>
<script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
<script src="~/lib/tempusdominus/js/moment.min.js"></script>
<script src="~/lib/tempusdominus/js/moment-timezone.min.js"></script>
<script src="~/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>

<!-- Template Javascript -->
<script src="~/js/main.js"></script>