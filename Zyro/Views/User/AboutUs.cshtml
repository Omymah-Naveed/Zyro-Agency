@model IndexViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "AboutUs";

}

<!-- Header Start -->
<div class="container-fluid bg-breadcrumb">
    <ul class="breadcrumb-animation">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>
    <div class="container text-center py-3" style="max-width: 900px;">

        <h3 class="display-3 mb-4 wow fadeInDown" data-wow-delay="0.1s">About Us</h3>
        <ol class="breadcrumb justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s" style="font-size:16px;">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" style="color:#2373AE;">About Us</li>
            @* <li class="breadcrumb-item"><a asp-controller="User" asp-action="Login">Log In</a></li> *@
        </ol>
    </div>
</div>
<!-- Header End -->
<!-- About Start -->
<div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 900px;">
    <h1 class="mb-1" style="color:#2373AE; font-weight:bold;">About Us</h1>
    <h3 class="display-5 mb-4" style="color:#182536;">Turning ideas into reality with dedication.</h3>
</div>
<div class="container-fluid overflow-hidden pt-3 pb-5">
    <div class="container py-5">
        <div class="row g-5">

            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="RotateMoveLeft" style="padding:3%;">
                    <img src="~/img/aboutus-img.png" class="img-fluid w-100" alt="" style="margin-top: -30px;">
                </div>
            </div>

            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.3s" style="padding-top:3%;">
                @if (Model.AboutusList != null && Model.AboutusList.Any())
                {
                    var about = Model.AboutusList.First(); <!-- we pick first record -->

                    <h1 class="display-5 mb-4" style="color:#2d2c2c; font-weight:800;">
                        @about.Title
                    </h1>
                    <p class="mb-4" style="font-size:20px; color:#182536;">
                        @Html.Raw(about.Description)
                    </p>

                    <div style="padding-top:10%;">
                        <h1 class="display-5 mb-4" style="color:#2d2c2c; font-weight:800;">
                            @about.TitleTwo
                        </h1>
                        <p class="mb-4" style="font-size:20px; color:#182536;">
                            @Html.Raw(about.DescriptionTwo)
                        </p>
                    </div>
                }
                else
                {
                    <p>No About Us information available.</p>
                }
            </div>
        </div>
    </div>
</div>
<!-- About End -->


<!-- Banner with Video Start -->
<div class="container-fluid banner-section py-5 position-relative">
    <video autoplay muted loop class="banner-video">
        <source src="~/img/about-banner-video.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="banner-overlay"></div>
    <div class="banner-content">
        <!-- Removed text-center from container -->
        <h2 class="banner-title text-light mb-3">Develop Your Mobile App With Us</h2>
        <p class="banner-subtitle mb-4">For those of you who want to develop your mobile application. Contact us immediately, because we are the right people to help you.</p>
        <a asp-controller="User" asp-action="Services" class="btn zyro-btn rounded-pill py-3 px-5 wow fadeInUp" data-wow-delay="0.7s">Get Service</a>


    </div>
</div>
<!-- Banner with Video End -->


<!-- Feature Start -->
<div class="container-fluid feature overflow-hidden py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 900px;">
            <h1 class="mb-1" style="color:#2373AE; font-weight:bold;">Our Features</h1>
            <h3 class="display-5 mb-2">Push Your Visitors Into Happy Customers</h3>
           
        </div>
       
        <div class="row g-5 pt-5">
            <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.1s">
                <div class="feature-img RotateMoveLeft d-flex align-items-center justify-content-center mx-auto"
                     style="width: 450px; height: 450px; padding: 1rem; transform: translateY(-30px);">
                    <img src="~/img/our-features.png" class="img-fluid"
                         style="max-width: 100%; max-height: 100%; object-fit: contain;"
                         alt="Our Features">
                </div>
            </div>



            <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.1s">
                <h1 class="display-6 mb-4 mt-2">Trusted by Thousands, Valued by All.</h1>
                <p class="mb-4" style="font-size: 20px;">
                    Empowering businesses with results-driven strategies and measurable growth.
                </p>
                <div class="row g-4">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <img src="~/img/projects-created.png" alt="Projects Created" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                            <div class="d-flex flex-column ms-3">
                                <h2 class="mb-0 fw-bold counter" data-target="285">0</h2>
                                <small class="text-dark">Created Projects</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <img src="~/img/happy-clients.png" alt="Happy Clients" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                            <div class="d-flex flex-column ms-3">
                                <h2 class="mb-0 fw-bold counter" data-target="6560">0</h2>
                                <small class="text-dark">Happy Clients</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<!-- Feature End -->
