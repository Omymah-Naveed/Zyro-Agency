@model Zyro.Models.RegisterationUser
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}
<!-- Header Start -->
<div class="container-fluid bg-breadcrumb">
    <ul class="breadcrumb-animation">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>
    <div class="container text-center py-3" style="max-width: 900px;">
        <h3 class="display-3 mb-4 wow fadeInDown" data-wow-delay="0.1s">Login</h3>
        <ol class="breadcrumb justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s" style="font-size:16px;">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            @* <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Services">Services</a></li> *@
            <li class="breadcrumb-item active" aria-current="page" style="color:#2373AE;">Login</li>
        </ol>
    </div>
</div>
<!-- Header End -->
<!-- Login Section Start -->
<div class="container-fluid contact py-5 ">
    <div class="container py-5">
        <div class="row g-5 align-items-center">

            <!-- Login Form -->
            <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.1s">
                <div class="bg-white rounded shadow p-5">
                    <h4 class="text-center mb-4 fw-bold" style="color: #2373AE; font-family:Arial, Helvetica, sans-serif;">Welcome Back</h4>
                    @foreach (var key in new[] { "SuccessMessageLoginOne", "SuccessMessageSignup", "ErrorMessageLogin", "ErrorMessageLoginOne", "ErrorMessageFreeze" })
                    {
                        if (TempData[key] != null)
                        {
                            var alertClass = key.StartsWith("Error") ? "alert-danger" : "alert-success";
                            <div class="alert @alertClass alert-dismissible fade show text-center" role="alert">
                                @TempData[key]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                    }
                    <form asp-action="Login">
                        <div asp-validation-summary="ModelOnly" class="text-danger text-center"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Email" type="email" class="form-control" placeholder="Email" required />
                            <label asp-for="Email"><i class="fas fa-envelope me-2"></i> Email</label>
                        </div>
                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Password" id="passwordInput" class="form-control" type="password" placeholder="Enter your password" required />
                            <label asp-for="Password"><i class="fas fa-lock me-2"></i> Password</label>
                            <span class="position-absolute top-50 end-0 translate-middle-y pe-3" onclick="togglePassword()" style="cursor:pointer;">
                                <!-- Default: password hidden, so icon is eye-slash -->
                                <i class="fas fa-eye-slash" id="eyeIcon"></i>
                            </span>
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn custom-login-btn py-2 rounded-pill">Login</button>
                        </div>
                        <div class="text-center">
                            <span class="text-muted">Don't have an account?</span>
                            <a asp-controller="User" asp-action="Signup" style="color:#2373AE;">Sign Up</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Marketing Cards -->
            <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.3s">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light d-flex align-items-center justify-content-center mb-3"
                         style="width: 90px; height: 90px; border-radius: 50px;">
                        <img src="~/img/Seo-loginform.png" alt="Seo" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                    </div>
                    <div class="ms-4">
                        <h4>SEO Optimization</h4>
                        <p class="mb-0">Improve your website’s visibility and rank higher on search engines.</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light d-flex align-items-center justify-content-center mb-3"
                         style="width: 90px; height: 90px; border-radius: 50px;">
                        <img src="~/img/social-media-loginform.png" alt="Social Media Maketing" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                    </div>
                    <div class="ms-4">
                        <h4>Social Media Marketing</h4>
                        <p class="mb-0">Engage your audience and grow your presence across all platforms.</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light d-flex align-items-center justify-content-center mb-3"
                         style="width: 90px; height: 90px; border-radius: 50px;">
                        <img src="~/img/web-design-loginform.png" alt="Web Design" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                    </div>
                    <div class="ms-4">
                        <h4>Website Design</h4>
                        <p class="mb-0">Craft intuitive and user-friendly interfaces for better engagement and usability.</p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light d-flex align-items-center justify-content-center mb-3"
                         style="width: 90px; height: 90px; border-radius: 50px;">
                        <img src="~/img/app-development-loginform.png" alt="App Development" class="img-fluid" style="max-width: 60px; max-height: 60px;">
                    </div>
                    <div class="ms-4">
                        <h4>App Development</h4>
                        <p class="mb-0">Develop fast, responsive mobile apps tailored to your business needs.</p>
                    </div>
                </div>

                
            </div>

        </div>
    </div>
</div>
<!-- Login Section End -->
@section Scripts {
    <script>
        function togglePassword() {
            var passwordField = document.getElementById("passwordInput");
            var eyeIcon = document.getElementById("eyeIcon");

            if (passwordField.type === "password") {
                passwordField.type = "text";
                eyeIcon.classList.remove("fa-eye-slash");
                eyeIcon.classList.add("fa-eye");
            } else {
                passwordField.type = "password";
                eyeIcon.classList.remove("fa-eye");
                eyeIcon.classList.add("fa-eye-slash");
            }
        }
    </script>
}
