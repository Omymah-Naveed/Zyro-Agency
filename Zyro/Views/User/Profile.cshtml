            autoplayTimeout: 3000,
            smartSpeed: 600,
            items: 1
        });

        $(".testimonial-carousel").owlCarousel({
    loop: false, // don't loop
    margin: 20,
    nav: true,
    dots: true,
    autoplay: false, // disable auto sliding
    smartSpeed: 600,
    items: 1
});

        // Fix for modals inside carousel
        $(document).on('click', '.view-blog-btn', function () {
            var modalId = $(this).data("bs-target");
            $(modalId).modal('show');
        });
    });
</script>

            <!-- Keep only one jQuery in your _Layout -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
(function () {
    const modalEl = document.getElementById('chatModal'); // your modal id
    let refreshTimer = null;

    function initChat(root) {
        const chatMessagesContainer = root.querySelector("#chatMessages");
        const searchInput = root.querySelector("#searchInput");
        const dateFilter = root.querySelector("#dateFilter");
        const clearFilters = root.querySelector("#clearFilters");
        const contactId = root.dataset.contactId;

        function highlightMatch(text, term) {
            if (!term) return text;
            const regex = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
            return text.replace(regex, '<mark style="background:yellow;">$1</mark>');
        }

        function applyFilters() {
            const searchTerm = (searchInput?.value || "").toLowerCase();
            const selectedDate = dateFilter?.value || ""; // yyyy-MM-dd
            document.querySelectorAll(".chat-message").forEach(msg => {
                const messageTextElem = msg.querySelector(".message-text");
                const originalText = messageTextElem.textContent;
                const textMatch = originalText.toLowerCase().includes(searchTerm);
                const dateMatch = !selectedDate || msg.dataset.date === selectedDate;
                messageTextElem.innerHTML = highlightMatch(originalText, searchTerm);
                msg.style.display = (textMatch && dateMatch) ? "block" : "none";
            });
        }

        function scrollToBottom() {
            chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
        }
        function isNearBottom() {
            return chatMessagesContainer.scrollHeight - chatMessagesContainer.scrollTop <= chatMessagesContainer.clientHeight + 50;
        }

        // Bind UI events
        clearFilters?.addEventListener("click", () => {
            if (searchInput) searchInput.value = "";
            if (dateFilter) dateFilter.value = "";
            applyFilters();
        });
        searchInput?.addEventListener("input", applyFilters);
        dateFilter?.addEventListener("change", applyFilters);

        // AJAX reload (user endpoint)
        function reloadMessages() {
            $.get(`/User/ViewContactChat?contactId=${contactId}`, function (data) {
                const newMessagesHtml = $(data).find("#chatMessages").html();
                if (newMessagesHtml) {
                    const wasNear = isNearBottom();
                    $("#chatMessages").html(newMessagesHtml);
                    applyFilters();
                    // Auto scroll if user was at bottom (no jump while reading history)
                    if (wasNear) scrollToBottom();
                }
            });
        }

        // Initial state
        scrollToBottom();
        applyFilters();

        // Start auto refresh
        refreshTimer = setInterval(reloadMessages, 5000);
    }

    // Init when modal is fully shown
    modalEl.addEventListener('shown.bs.modal', function () {
        // Prevent stacking multiple timers when reopened
        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
        const root = modalEl.querySelector("#chatRoot");
        if (root) initChat(root);
    });

    // Cleanup on hide
    modalEl.addEventListener('hidden.bs.modal', function () {
        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
    });
})();
</script>
