@model Zyro.Models.ProfileViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Profile";

    var userEmail = Context.Session.GetString("useremail") ?? "";
    var userBlogs = Model.Blogs;
}

<!-- Styles -->
<link href="~/css/profile.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css" />


<style>
    /* Active nav-pill style */
    .nav-pills .nav-link.active {
        background-color: #235695 !important;
        color: #fff !important;
    }

    /* Normal state text color (optional, readable) */
    .nav-pills .nav-link {
        color: #235695;
    }

    /* Custom button styling for Orders section */
    .card .btn.btn-orders-tab.btn-sm {
        background-color: #235695;
        border: 1px solid #235695;
        color: #fff;
        font-family: 'Segoe UI', sans-serif;
        transition: all 0.4s ease;
        margin-right:8px;
    }

        /* Hover state */
        .card .btn.btn-orders-tab.btn-sm:hover {
            background-color: #fff !important;
            color: #235695 !important;
            border: 1px solid #235695 !important;
            box-shadow: 0 4px 10px rgba(35, 86, 149, 0.3);
            transform: scale(1.05);
        }

        /* Focus + Active state */
        .card .btn.btn-orders-tab.btn-sm:focus,
        .card .btn.btn-orders-tab.btn-sm:active {
            
            
            background-color: #fff !important;
            color: #235695 !important;
            border: 1px solid #235695 !important;
            box-shadow: 0 0 0 4px rgba(68, 177, 218, 0.4);
        }

</style>

<!-- Header Start -->
<div class="container-fluid bg-breadcrumb">
    <ul class="breadcrumb-animation">
        @for (int i = 0; i < 10; i++) { <li></li> }
    </ul>
    <div class="container text-center py-3" style="max-width: 900px;">
        <h3 class="display-3 mb-4 wow fadeInDown">My Profile</h3>
        <ol class="breadcrumb justify-content-center mb-0 wow fadeInDown" style="font-size:16px;">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" style="color:#2373AE;">My Profile</li>
        </ol>
    </div>
</div>  
<!-- Header End -->

<!-- Profile Tabs Section Start -->
<div class="container py-3" style="margin-top:-10px;">

    <!-- Success Messages -->
    @foreach (var key in new[] { "SuccessMessageOrder", "SuccessMessageTestimonials", "SuccessMessageProfile", "SuccessMessageAddBlog" , "SuccessMessageContactDelete", "SuccessMessageOrderdelete", "SuccessMessageBlog","SuccessMessageOrderMeeting"})
    {
        if (TempData[key] != null)
        {
            <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
                @TempData[key]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    }

    <!-- Section Heading -->
    <div class="text-center mx-auto mb-5" style="max-width: 900px;">
        <h3 class="mb-1" style="color:#2373AE; font-weight:bold;">My Profile</h3>
        <h1 class="display-5 mb-4" style="color:#182536; white-space:nowrap; font-size:2rem;">
            Track, Manage, and Grow with Zyro Agency.
        </h1>
    </div>

    <!-- Tabs Navigation -->
    <div class="tab-wrapper mx-auto">
        <ul class="nav nav-tabs justify-content-center" id="profileTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button">
                    Profile Info
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="blogs-tab" data-bs-toggle="tab" data-bs-target="#blogs" type="button">
                    My Blogs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button">
                    Orders
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="contact-reviews-tab" data-bs-toggle="tab" href="#contact-reviews" type="button">
                    Contact Us / Reviews
                </button>
            </li>
        </ul>

        <div class="tab-content p-4 border border-top-0 shadow-sm rounded-bottom" id="profileTabsContent">

            <!-- Profile Info Tab -->
<!-- Profile Info Tab -->
<div class="tab-pane fade show active" id="profile" role="tabpanel">
    <h4>Profile Information</h4>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="text-center">
            <img src="~/profile_images/@Model.User?.ImagePath" 
                 alt="Profile Picture" 
                 class="rounded-circle mb-3" 
                 style="width:120px; height:120px; object-fit:cover; box-shadow:0 4px 10px rgba(0,0,0,0.2);" />
                 </div>
            <!-- User Details -->
            <h5 class="card-title">@Model.User?.Name</h5>
            <p><strong>Email:</strong> @Model.User?.Email</p>
            <p><strong>Age:</strong> @Model.User?.Age</p>
            <p><strong>City:</strong> @Model.User?.City</p>

            <div class="d-flex justify-content-end">
                <a asp-action="EditProfile" asp-route-id="@Model.User?.Id"
                   class="btn btn-warning btn-sm"
                   style="font-size:16px;font-weight:500;">
                    Edit
                </a>
            </div>
        </div>
    </div>
</div>


            <!-- My Blogs Tab -->
            <div class="tab-pane fade" id="blogs" role="tabpanel">
                <h4>My Blogs</h4>

                <div class="d-flex justify-content-end mb-3">
                    <a asp-controller="User" asp-action="AddBlog" class="btn btn-success"
                       style="font-size:16px;font-weight: 500;">+ Add Blog</a>
                </div>

                @if (!Model.Blogs.Any())
                {
                    <div class="alert alert-warning text-center">No approved blogs found.</div>
                }
                else
                {
                    <div class="owl-carousel blog-carousel">
                        @foreach (var blog in userBlogs)
                        {
                            <div class="item">
                                <div class="card shadow-sm text-center p-3">
                                    <img src="~/img/blogspic.png" class="card-img-top blog-img" alt="Blog Image">
                                    <div class="card-body">
                                        <h5 class="card-title">@blog.Title</h5>
                                        <p class="text-muted">Posted by: @blog.Name</p>
                                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                                            <button class="btn btn-info btn-sm view-blog-btn"
                                                    data-bs-target="#blogModal-@blog.Id">
                                                View
                                            </button>
                                            <a asp-action="EditBlog" asp-route-id="@blog.Id" class="btn btn-warning btn-sm">
                                                Edit
                                            </a>
                                            <form asp-action="DeleteBlog" method="post"
                                                  onsubmit="return confirm('Are you sure you want to delete this blog?');"
                                                  style="display:inline;">
                                                <input type="hidden" name="id" value="@blog.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Blog Modals -->
                    @foreach (var blog in userBlogs)
                    {
                        <div class="modal fade" id="blogModal-@blog.Id" tabindex="-1"
                             aria-labelledby="blogModalLabel-@blog.Id" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header" style="background-color:#235695;">
                                        <h5 class="modal-title" style="color:white;">@blog.Title</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                style="filter: invert(1) grayscale(100%) brightness(200%);"></button>
                                    </div>
                                    <div class="modal-body"
                                         style="max-height:400px; overflow-y:auto; word-wrap:break-word; white-space:pre-wrap;">
                                        <p style="font-size:18px; color:black;">@blog.Description</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

<!-- Orders Tab -->
<div class="tab-pane fade" id="orders" role="tabpanel">
    <h4>Orders</h4>

    @{
        var activeOrders = Model.Orders.Where(o => o.Status?.ToLower() != "completed").ToList();
        var completedOrders = Model.Orders.Where(o => o.Status?.ToLower() == "completed").ToList();
        bool hasHistory = completedOrders.Any();
    }

    <div style="max-height:400px; overflow-y:auto; padding-right:5px;">
        @if (!activeOrders.Any())
        {
            <div class="alert alert-warning text-center">No active orders found.</div>
        }

        @foreach (var order in activeOrders)
        {
            var badgeClass = order.Status?.ToLower() switch
            {
                "pending" => "bg-warning text-dark",
                "in progress" => "bg-info text-dark",
                _ => "bg-secondary"
            };

            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <p><strong>Order ID:</strong> #@order.Id</p>
                    <p><strong>Service:</strong> @order.Service</p>
                    <p><strong>Date:</strong> @order.OrderDate</p>
                    <p>
                        <strong>Status:</strong>
                        <span class="badge @badgeClass">@order.Status</span>
                    </p>
                    <button class="btn btn-orders-tab btn-sm" data-bs-toggle="modal"
                            data-bs-target="#orderModal-@order.Id">
                        View Details
                    </button>

                    @if (order.Status != "Pending")
                    {
                        <a asp-controller="User" asp-action="Meeting" asp-route-id="@order.Id"
                           class="btn btn-orders-tab btn-sm">
                            Request A Meeting
                        </a>
                    }
                    @if (order.Status == "Pending")
                    {
                        <form asp-action="DeleteOrders" method="post" 
                              onsubmit="return confirm('Are you sure you want to delete this order?');"
                              style="display:inline;">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button type="submit" class="btn btn-orders-tab btn-sm">Delete</button>
                        </form>
                    }
                </div>
            </div>

            <!-- Order Details Modal -->
            <div class="modal fade" id="orderModal-@order.Id" tabindex="-1"
                 aria-labelledby="orderModalLabel-@order.Id" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header" style="background-color:#235695;">
                            <h5 class="modal-title" style="color:white;">
                                Order Details - #@order.Id
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    style="filter: invert(1) grayscale(100%) brightness(200%);"></button>
                        </div>
                        <div class="modal-body">
                            <p><strong>Name:</strong> @order.Name</p>
                            <p><strong>Email:</strong> @order.Email</p>
                            <p><strong>Service:</strong> @order.Service</p>
                            <p><strong>Date:</strong> @order.OrderDate</p>
                            <p><strong>Status:</strong> @order.Status</p>
                            <p><strong>Meeting Date:</strong> @order.Date</p>
                            <p><strong>Meeting Time:</strong> @order.Time</p>
                            <p><strong>Link:</strong> @order.MeetingText</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Show history button even if there are no active orders -->
        @if (hasHistory)
        {
            <div class="d-flex justify-content-end mb-3">
                            <button class="btn btn-orders-tab btn-sm" data-bs-toggle="modal" data-bs-target="#historyModal">
                    View History
                </button>
            </div>
        }
    </div>

    <!-- History Modal -->
    @if (hasHistory)
    {
        <div class="modal fade" id="historyModal" tabindex="-1"
             aria-labelledby="historyModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                                <div class="modal-header" style="background-color:#235695;">
                        <h5 class="modal-title" style="color:white;">Order History</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                style="filter: invert(1) grayscale(100%) brightness(200%);"></button>
                    </div>
                    <div class="modal-body">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Service</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Review</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in completedOrders)
                                {
                                    <tr>
                                        <td>#@order.Id</td>
                                        <td>@order.Service</td>
                                        <td>@order.OrderDate</td>
                                        <td><span class="badge bg-success">Completed</span></td>
                                        <td>
                                            @if (order.Status == "Completed")
                                            {
                                                <a asp-controller="User" asp-action="Testimonials" 
                                                   class="btn custom-login-btn rounded-pill py-2 px-4 ms-auto w-100">
                                                    Review
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>


            <!-- Contact / Reviews Tab -->
            <div class="tab-pane fade show" id="contact-reviews" role="tabpanel">

                <!-- Sub-tabs for Reviews and Contacts -->
                <ul class="nav nav-pills mb-3" id="subTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="reviews-tab" data-bs-toggle="pill" href="#reviews" role="tab">
                            ★ Reviews
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="contacts-tab" data-bs-toggle="pill" href="#contacts" role="tab">
                            ✉ Contacts
                        </a>
                    </li>
                </ul>

                <!-- Sub-tab Content -->
                <div class="tab-content">
                    <!-- Reviews Tab -->
                    <div class="tab-pane fade show active" id="reviews" role="tabpanel">
                        @if (Model.Tes != null && Model.Tes.Any())
                        {
                            <div class="list-group">
                                @foreach (var t in Model.Tes.DistinctBy(x => x.Id))
                                {
                                    <div class="list-group-item">
                                        <strong>@t.Name</strong> <span class="text-muted">(@t.Email)</span>
                                        <p class="mb-0">@t.Remarks</p>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="alert alert-warning text-center">No reviews yet.</p>
                        }
                    </div>

                    <!-- Contacts Tab -->
                    <div class="tab-pane fade" id="contacts" role="tabpanel">
                        @if (Model.Con != null && Model.Con.Any())
                        {
                            <div style="max-height:400px; overflow-y:auto; padding-right:5px;">
                                @foreach (var c in Model.Con.OrderByDescending(c => c.Id))
                                {
                                    <div class="card mb-3 shadow-sm">
                                        <div class="card-body">
                                            <p><strong>Project:</strong> @c.Project</p>
                                            <p><strong>Date:</strong> @c.Date</p>
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-orders-tab btn-sm" data-bs-toggle="modal" data-bs-target="#contactModal-@c.Id">
                                                    View Details
                                                </button>
<a href="@Url.Action("ViewContactChat", "User", new { contactId = c.Id })"
                                                   class="btn btn-sm btn-orders-tab open-chat"
   data-contact-modal="#contactModal-@c.Id">
    Open Chat
</a>
                                            
                                                <form asp-action="DeleteContact" method="post" style="display:inline;"
                                                      onsubmit="return confirm('Are you sure you want to delete this contact?');">
                                                    <input type="hidden" name="id" value="@c.Id" />
                                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Contact Details Modal -->
                                    <div class="modal fade" id="contactModal-@c.Id" tabindex="-1"
                                         aria-labelledby="contactModalLabel-@c.Id" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header" style="background-color:#235695;">
                                                    <h5 class="modal-title" style="color:white;">Contact Details</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                            style="filter: invert(1) grayscale(100%) brightness(200%);"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p><strong>Name:</strong> @c.Name</p>
                                                    <p><strong>Email:</strong> @c.Email</p>
                                                    <p><strong>Phone:</strong> @c.Phone</p>
                                                    <p><strong>Project:</strong> @c.Project</p>
                                                    <p><strong>Subject:</strong> @c.Subject</p>
                                                    <p><strong>Message:</strong> @c.Message</p>
                                                    <p><strong>Date:</strong> @c.Date</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                }
                                <!-- Chat Modal -->
<div class="modal fade" id="chatModal" tabindex="-1">
    <div class="modal-dialog modal-sm mt-5">
        <div class="modal-content" id="chatModalContent">
            <!-- Chat will be loaded here -->
        </div>
    </div>
</div>

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">No contacts found.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Profile Tabs Section End -->

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
