@model Zyro.Models.ProfileJourneyViewModel
@{
    // Layout = "_Layout";
    ViewData["Title"] = "Welcome";
}
<head>
    <meta charset="utf-8">
    <title>ZYRO AGENCY</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700&family=Rubik:wght@400;500&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/lib/lightbox/css/lightbox.min.css" rel="stylesheet">


    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css" />
    <link href="~/css/user_style.css" rel="stylesheet">
    <link href="~/css/forms.css" rel="stylesheet">
    <link href="~/css/blog.css" rel="stylesheet">
    <link href="~/css/faqs.css" rel="stylesheet">
    <link href="~/css/singlepageheader.css" rel="stylesheet">

</head>



<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link href="~/css/welcomepage.css" rel="stylesheet" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9">

            <!-- Welcome Header -->
            <header class="welcome-header text-white py-5 mb-0" style="background: linear-gradient(90deg, #2373AC, #1a5a87);">
                <div class="container text-center">
                    <h1 class="fw-bold mb-2">Let’s get your profile completed and unlock full access 🚀</h1>
                </div>
            </header>
            @* ============================= *@


            @* welcome banner *@

            <!-- Clean Welcome Banner (Text Over Image) -->
            <section class="welcome-banner text-center my-5"
                     style="
background-image: url('/img/welcome-banner.svg');
background-repeat: no-repeat;
background-position: center;
background-size: cover;
height: 450px;
position: relative;
color: #fff;
padding-top: 40px;
padding-bottom: 40px;">
                <div class="container d-flex flex-column justify-content-start align-items-center h-100" style="padding-top: 150px;">
                    <!-- Overlay Text -->
                    
                    <h2 class="fw-bold mb-2" style="color:#235695;">Welcome to</h2>
                    <h2 class="fw-bold mb-2" style="color:#235695;">ZYRO AGENCY</h2>
                    <h1 style="color:#235695;font-weight:bold;">Hello, @Model.Name 👋</h1>
                    <p class="lead fw-bold fs-4 text-dark text-center">
                        We’re proud that you choose <br>
                        to join our company
                    </p>
                </div>
            </section>
            @* ============================== *@
  

            <!-- Steps Header -->
            <header class="welcome-header text-white py-5 mb-0" style="background: linear-gradient(90deg, #2373AC, #1a5a87);">
                <div class="container text-center">
                    <h1 class="fw-bold mb-2"> Please finish the steps below to complete your profile setup 🌟</h1>
                </div>
            </header>
            @* =================================== *@


            <!-- Steps -->
            <div class="row g-3  mt-4">

                <!-- Step: Phone -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#phoneModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasPhone)
                                {
                                    <i class="bi bi-telephone-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-telephone-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 1: Add Phone</h6>
                                    @if (Model.HasPhone)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasPhone)
                                    {
                                        @Model.Phone
                                    }
                                    else
                                    {
                                        @:No phone provided
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: Profile Picture -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#pictureModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasProfilePicture)
                                {
                                    <i class="bi bi-person-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-person-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 2: Upload Profile Picture</h6>
                                    @if (Model.HasProfilePicture)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasProfilePicture)
                                    {
                                        @:Picture uploaded
                                    }
                                    else
                                    {
                                        @:No picture uploaded
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: City -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#cityModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasCity)
                                {
                                    <i class="bi bi-geo-alt-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-geo-alt text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 3: Select City</h6>
                                    @if (Model.HasCity)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasCity)
                                    {
                                        @Model.City
                                    }
                                    else
                                    {
                                        @:No city selected
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step: Age -->
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#ageModal" style="cursor:pointer;">
                        <div class="card-body d-flex">
                            <div class="me-3 fs-3">
                                @if (Model.HasAge)
                                {
                                    <i class="bi bi-calendar-check text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-calendar-x text-danger"></i>
                                }
                            </div>
                            <div>
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0">Step 4: Add Age</h6>
                                    @if (Model.HasAge)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-2">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-2">Missing</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    @if (Model.HasAge)
                                    {
                                        @Model.Age
                                    }
                                    else
                                    {
                                        @:No age provided
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.HasPhone && Model.HasProfilePicture && Model.HasCity && Model.HasAge)
            {
                <div class="d-grid mt-4">
                    <form asp-action="SaveProfile" asp-controller="User" method="post" enctype="multipart/form-data">
                        <button type="submit" class="btn btn-save btn-lg rounded-pill">
                            Save Profile
                        </button>
                    </form>
                </div>
            }

            <!-- About Website -->
            <div class="row mt-5 g-3">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100 text-center p-3 feature-card">
                        <i class="bi bi-shield-lock fs-2 mb-2"></i>
                        <h6 class="text-light">Secure & Reliable</h6>
                        <p>Your data is safe with us and fully encrypted.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100 text-center p-3 feature-card">
                        <i class="bi bi-stars fs-2 mb-2"></i>
                        <h6 class="text-light">Personalized</h6>
                        <p>Get tailored experiences and recommendations.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100 text-center p-3 feature-card">
                        <i class="bi bi-gear fs-2 mb-2"></i>
                        <h6 class="text-light">Easy Management</h6>
                        <p>Manage your profile and preferences easily.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


<!-- MODALS -->

<!-- Phone Modal -->
<div class="modal fade" id="phoneModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdatePhone" asp-controller="User" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Update Phone</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" name="Phone" class="form-control" placeholder="Enter phone number" value="@Model.Phone" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save Phone</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Profile Picture Modal -->
<div class="modal fade" id="pictureModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SaveImageWelcome" asp-controller="User" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Upload Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="file" name="ProfilePicture" class="form-control" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- City Modal -->
<div class="modal fade" id="cityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateCity" asp-controller="User" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Enter City</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" name="City" class="form-control" placeholder="Enter your city" value="@Model.City" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save City</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Age Modal -->
<div class="modal fade" id="ageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateAge" asp-controller="User" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Add Age</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="number" name="Age" class="form-control" placeholder="Enter your age" value="@Model.Age" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save Age</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- JavaScript Libraries -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/wow/wow.min.js"></script>
<script src="~/lib/easing/easing.min.js"></script>
<script src="~/lib/waypoints/waypoints.min.js"></script>
<script src="~/lib/counterup/counterup.min.js"></script>
<script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
<script src="~/lib/lightbox/js/lightbox.min.js"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Template Javascript -->
<script src="~/js/user_main.js"></script>
<script src="~/js/counter.js"></script>
<script src="~/js/profile.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://unpkg.com/isotope-layout@3/dist/isotope.pkgd.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>