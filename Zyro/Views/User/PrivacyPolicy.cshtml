@model PrivacyViewModel
@{
    ViewData["Title"] = "PrivacyPolicy";
    Layout = "_Layout";
}

<!-- Header Start -->
<div class="container-fluid bg-breadcrumb">
    <ul class="breadcrumb-animation">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>
    <div class="container text-center py-3" style="max-width: 900px;">
        <h3 class="display-3 mb-4 wow fadeInDown" data-wow-delay="0.1s">Privacy & Policy</h3>
        <ol class="breadcrumb justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s" style="font-size:16px;">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            @* <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Services">Services</a></li> *@
            <li class="breadcrumb-item active" aria-current="page" style="color:#2373AE;">Privacy & Policy</li>
        </ol>
    </div>
</div>
<!-- Header End -->
<!-- Privacy Policy Hero Section -->
<div class="container py-5">
    <div class="text-center mb-5 wow fadeInUp">
        <h1 class="display-4 mb-3" style="color:#2373AE; font-weight:bold;">Privacy Policy</h1>
        <p class="lead" style="font-size:18px; color:black;">
            At <span style="font-size:20px;font-weight:bold;color:#2373AE;">Zyro Agency</span>, we value your privacy and are committed to protecting your personal information.
        </p>
    </div>

    <!-- Policy Content -->
    <div class="row g-5 align-items-center">
        <div class="col-lg-6 wow fadeInLeft">
            <div class="policy-img RotateMoveLeft d-flex align-items-center justify-content-center mx-auto mb-4"
                 style="padding: 1rem; max-width: 100%;">
                <img src="~/img/privacypolicy1.png" alt="Privacy Policy" class="img-fluid"
                     style="max-width: 80%; height: auto;">
            </div>
        </div>

        <div class="col-lg-6 wow fadeInRight">
            <h3 class="mb-3" style="color:#225694; font-weight:bold;">Your Data Matters</h3>
            <p style="font-size: 18px;">
                We explain clearly how we collect, use, and protect your information when you visit our website or use our services.
            </p>
            <ul style="font-size: 16px;">
                <li>Information We Collect (name, contact, browsing data)</li>
                <li>How We Use Your Information (services, newsletters, support)</li>
                <li>Data Sharing & Third Parties</li>
                @* <li>Cookies & Tracking</li> *@
                <li>Security & Your Rights</li>
            </ul>
        </div>
    </div>
</div>



<!-- Detailed Privacy Sections with Images -->
<div class="container py-5">
    @foreach (var item in Model.PrivacyList)
    {
        <div class="row align-items-center mb-5">
            <div class="col-md-2 text-center">
                <img src="~/img/@item.ImagePath" alt="@item.Title" class="img-fluid" style="max-width:150px; height:auto;">
            </div>
            <div class="col-md-10">
                <h3 class="mb-2" style="color:#225694;">@item.Title</h3>
                <p>@Html.Raw(item.Description)</p>
            </div>
        </div>
    }
</div>