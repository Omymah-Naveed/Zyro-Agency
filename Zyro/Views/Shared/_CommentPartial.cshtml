@model Zyro.Models.BlogCommentViewModel

@* <div class="mb-3 border-bottom pb-2"> *@
    @* <strong>@Model.Name</strong> *@
    <small class="text-muted">@Model.CommentDate?.ToString("dd MMM yyyy")</small>
    <p class="mb-1">@Model.CommentText</p>
    @* <a href="javascript:void(0);" class="text-primary small reply-btn" data-comment-id="@Model.Id">Reply</a> *@

    @if (Model.Replies != null && Model.Replies.Any())
    {
        <div class="ms-4 mt-2 border-start ps-3">
            @foreach (var reply in Model.Replies)
            {
                @Html.Partial("_CommentPartial", reply)
            }
        </div>
    }
@* </div> *@
